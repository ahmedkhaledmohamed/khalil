<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pharoclaw.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Update this path if your Python venv is elsewhere -->
        <string>/Users/ahmedm/Developer/Personal/scripts/pharoclaw/.venv/bin/python3</string>
        <string>/Users/ahmedm/Developer/Personal/scripts/pharoclaw/server.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/ahmedm/Developer/Personal/scripts/pharoclaw</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/ahmedm/Developer/Personal/scripts/pharoclaw/data/pharoclaw.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/ahmedm/Developer/Personal/scripts/pharoclaw/data/pharoclaw.error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>PHAROCLAW_REPO</key>
        <string>/Users/ahmedm/Developer/Personal</string>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
