{
  "name": "pharoclaw-terminal-bridge",
  "displayName": "PharoClaw Terminal Bridge",
  "description": "Exposes Cursor's integrated terminal to PharoClaw via local HTTP",
  "version": "0.1.0",
  "publisher": "pharoclaw",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pharoclaw.terminalBridge.start",
        "title": "PharoClaw: Start Terminal Bridge"
      },
      {
        "command": "pharoclaw.terminalBridge.stop",
        "title": "PharoClaw: Stop Terminal Bridge"
      }
    ],
    "configuration": {
      "title": "PharoClaw Terminal Bridge",
      "properties": {
        "pharoclaw.terminalBridge.port": {
          "type": "number",
          "default": 8034,
          "description": "Port for the terminal bridge HTTP server"
        },
        "pharoclaw.terminalBridge.authToken": {
          "type": "string",
          "default": "",
          "description": "Shared secret for authenticating requests from PharoClaw"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
